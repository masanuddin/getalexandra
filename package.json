{
  "name": "getalexandra-photobooth",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n web,socket -c magenta,blue \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "next dev -p 3000",
    "dev:server": "tsx watch server/index.ts",
    "build": "next build",
    "start": "concurrently -n web,socket -c magenta,blue \"next start -p 3000\" \"tsx server/index.ts\"",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "next": "14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
