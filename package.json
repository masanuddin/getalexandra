{
  "name": "getalexandra-photobooth",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n web,worker -c magenta,blue \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "next dev -p 3000",
    "dev:server": "wrangler dev --config worker/wrangler.toml --port 3001",
    "build": "next build",
    "start": "next start -p 3000",
    "deploy:server": "wrangler deploy --config worker/wrangler.toml",
    "lint": "next lint",
    "typecheck": "tsc --noEmit && tsc -p worker --noEmit"
  },
  "dependencies": {
    "next": "14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260712.1",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "wrangler": "^4.110.0"
  }
}
