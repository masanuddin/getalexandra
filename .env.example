# --- web (Next.js) ---------------------------------------------------------
# URL of the realtime backend (Cloudflare Worker).
# Local dev: wrangler dev serves it on :3001 (see `npm run dev`).
# Production: your deployed worker, e.g. https://getalexandra-booth.<account>.workers.dev
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# --- TURN (WebRTC NAT traversal) ---------------------------------------------
# Production TURN uses Cloudflare Calls, configured as WORKER SECRETS (not here):
#   npx wrangler secret put TURN_KEY_ID --config worker/wrangler.toml
#   npx wrangler secret put TURN_KEY_API_TOKEN --config worker/wrangler.toml
# The worker then serves short-lived credentials at /api/turn.
#
# The vars below are only a static override (e.g. self-hosted coturn):
# NEXT_PUBLIC_TURN_URL=turn:turn.example.com:3478
# NEXT_PUBLIC_TURN_USERNAME=
# NEXT_PUBLIC_TURN_CREDENTIAL=
